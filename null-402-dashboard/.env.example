# Optional: point the dashboard at a deployed null-402 gateway Worker.
# Left blank, the dashboard uses its own embedded Next API routes (same origin).
NEXT_PUBLIC_GATEWAY_URL=

# Dev verifier secret — must match the gateway's DEV_SHARED_SECRET in dev mode.
DEV_SHARED_SECRET=change_me_dev_only

# Optional: CoinMarketCap key for real upstream price data.
CMC_API_KEY=
