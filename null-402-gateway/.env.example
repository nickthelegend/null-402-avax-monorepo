# ── null-402 / Avalanche Fuji ─────────────────────────────────────────────────
# Address this gateway is paid to (bound into every payment proof).
PAYMENT_PAYTO=0xyour_gateway_address

# EVM JSON-RPC + chain id (Fuji C-Chain).
EVM_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
EVM_CHAIN_ID=43113

# Deployed null-402 contracts on Fuji (live instances you can use as-is).
VERIFIER_CONTRACT_ID=0x0b44836dDc460f589ce4EB97f276e533A2bE6060
POOL_CONTRACT_ID=0x39a9C4EfabEBA954545Ecb4b16Ba1d92ec46cA1C

# Gateway-managed pool roots: comma-separated recent Merkle roots the gateway
# accepts (computed off-chain from on-chain deposits). Empty = accept any
# non-empty root (DEV ONLY — set this in production).
KNOWN_ROOTS=

# ── Verification mode ─────────────────────────────────────────────────────────
# "evm" = real on-chain Groth16 verification via eth_call (needs EVM_RPC_URL +
#         VERIFIER_CONTRACT_ID). "dev" = INSECURE local scaffold.
VERIFY_MODE=evm

# Shared secret for the dev verifier (dev mode only — meaningless in evm mode).
DEV_SHARED_SECRET=change_me_dev_only

# ── Upstream data (optional) ──────────────────────────────────────────────────
# CoinMarketCap API key for real price data. If absent, mock data is returned.
CMC_API_KEY=your_cmc_api_key_here
