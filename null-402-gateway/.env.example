# ── null-402 / Stellar ────────────────────────────────────────────────────────
# Account or contract this gateway is paid to (bound into every payment proof).
PAYMENT_PAYTO=your_stellar_account_or_contract_id

# Soroban RPC + network
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=testnet

# Deployed null-402 verifier contract (init'd with the circuit vk).
# Live testnet instance you can use as-is:
VERIFIER_CONTRACT_ID=CDCYYFSJ7QC7RO6L2DHWK6X6IMZ5U5J3IEAKLKTBTBDX45LWO32JQJLV
POOL_CONTRACT_ID=your_pool_contract_id

# Funded account public key used ONLY to simulate the verifier (read-only, no signing).
STELLAR_SOURCE_ACCOUNT=your_funded_testnet_account_G...

# Gateway-managed pool roots: comma-separated recent Merkle roots the gateway
# accepts (computed off-chain from on-chain deposits). Empty = accept any
# non-empty root (DEV ONLY — set this in production).
KNOWN_ROOTS=

# ── Verification mode ─────────────────────────────────────────────────────────
# "soroban" = real on-chain Groth16 verification (needs VERIFIER_CONTRACT_ID +
#             STELLAR_SOURCE_ACCOUNT). "dev" = INSECURE local scaffold.
VERIFY_MODE=dev

# Shared secret for the dev verifier (dev mode only — meaningless in soroban mode).
DEV_SHARED_SECRET=change_me_dev_only

# ── Upstream data (optional) ──────────────────────────────────────────────────
# CoinMarketCap API key for real price data. If absent, mock data is returned.
CMC_API_KEY=your_cmc_api_key_here
